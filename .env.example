# SAMSUNG LIONS WEB APP - Environment Variables Example
# Vercel 배포 시 아래 변수들을 설정해 주세요. (Fill in these variables on Vercel deployment)

# --- DATABASE CONFIG ---
# PostgreSQL connection string for future DB integration
DATABASE_URL="postgres://user:password@host:port/database"

# --- CMS / API CONFIG ---
# Authentication secret for administrative actions
NEXTAUTH_SECRET="your-secret-key-here"
NEXT_PUBLIC_API_URL="https://your-domain.com/api"

# --- MEDIA CONFIG ---
# Cloudinary or AWS S3 credentials for image hosting
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# --- ANALYTICS ---
# Google Analytics ID
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- OPTIMIZATION ---
# Flag to enable/disable specific premium features
ENABLE_PREMIUM_ANIMATIONS=true
