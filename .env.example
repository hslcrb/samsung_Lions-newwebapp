# SAMSUNG LIONS WEB APP - Environment Variables Example (DEMO MODE)
# 데모 버전이므로 현재 모든 환경 변수는 선택 사항입니다. (All variables are optional for demo)

# --- DATABASE CONFIG (OPTIONAL) ---
# DATABASE_URL="postgres://user:password@host:port/database"

# --- CMS / API CONFIG (OPTIONAL) ---
# NEXTAUTH_SECRET="your-secret-key-here"
# NEXT_PUBLIC_API_URL="https://your-domain.com/api"

# --- MEDIA CONFIG (OPTIONAL) ---
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# --- ANALYTICS (OPTIONAL) ---
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- OPTIMIZATION ---
ENABLE_PREMIUM_ANIMATIONS=true
